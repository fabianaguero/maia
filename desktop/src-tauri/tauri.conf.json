{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maia",
  "version": "0.1.0",
  "identifier": "com.fabianaguero.maia",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Maia",
        "width": 1460,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}

