{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Maia",
  "version": "0.1.0",
  "identifier": "com.fabianaguero.maia",
  "build": {
    "beforeDevCommand": "npx vite --port 1421 --host 127.0.0.1",
    "beforeBuildCommand": "npx vite build",
    "devUrl": "http://127.0.0.1:1421",
    "frontendDist": "../dist"
  },
  "app": {
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' asset: http://127.0.0.1:1421; media-src asset: blob: http://127.0.0.1:1421; img-src 'self' asset: data: blob: http://127.0.0.1:1421 https:",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "/media/**",
          "/mnt/**",
          "/tmp/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Maia",
        "width": 1460,
        "height": 940,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": false
  }
}
